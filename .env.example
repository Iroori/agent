# Agent Configuration Loading
AGENT_CONFIG_LOAD_TYPE=local-config  # local-config or seedai-api
SEEDAI_API_URL=
SEEDAI_API_KEY=

# Default Model Configuration
DEFAULT_MODEL_TYPE=gpt  # gpt, claude, ollama, gemini, grok, friendli, luxia

# OpenAI Configuration
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_MODEL=gpt-4o
OPENAI_TEMPERATURE=0.7
OPENAI_MAX_TOKENS=4096
OPENAI_BASE_URL=

# Anthropic (Claude) Configuration
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# Ollama Configuration
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Google (Gemini) Configuration
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-1.5-pro

# xAI (Grok) Configuration
XAI_API_KEY=
GROK_MODEL=grok-2-latest

# Friendli Configuration
FRIENDLI_API_KEY=
FRIENDLI_MODEL=

# Luxia Configuration
LUXIA_API_KEY=
LUXIA_BASE_URL=
LUXIA_MODEL=

# Agent Pool Configuration
AGENT_POOL_MAX_SIZE=100
AGENT_IDLE_TIMEOUT_SECONDS=3600

# Server Configuration
HOST=0.0.0.0
PORT=8000
DEBUG=false

# Logging Configuration
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE_PATH=./logs/antigravity.log
LOG_ROTATION_BACKUP_COUNT=30
TOOL_LATENCY_WARNING_THRESHOLD_SECS=5.0
LOG_SENSITIVE_MASKING=true

# Agent Configuration Directory
AGENTS_CONFIG_DIR=./agents_config

# Retry Configuration
MAX_RETRIES=3
RETRY_BASE_DELAY=1.0
